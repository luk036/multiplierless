# Flake8 configuration - Black compatible with meaningful checks enabled
[flake8]
max_line_length = 88
extend_ignore = E203, W503
# ^  Black-compatible
#    E203 and W503 have edge cases handled by black
exclude =
    .tox
    build
    dist
    .eggs
    docs/conf.py
    __pycache__
    .git
    .pytest_cache

